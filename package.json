{
  "name": "postals-mcp",
  "version": "1.0.0",
  "mcpName": "io.github.coopergwrenn/postals-mcp",
  "description": "Postals — the agent skill that turns any AI into a direct mail machine. One MCP tool call mails a physical handwritten postcard (real pen-and-ink, USPS 3-5 day delivery, $4.99 per card). Works with Claude Desktop, Cursor, Claude Code, OpenClaw, n8n, LangChain, and any MCP-compatible client.",
  "type": "module",
  "bin": {
    "postals-mcp": "build/index.js"
  },
  "main": "./build/index.js",
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "dev": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js",
    "start": "node build/index.js",
    "test": "node test-harness.mjs",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "build",
    "README.md",
    "SKILL.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "postals",
    "postcards",
    "handwritten",
    "direct-mail",
    "physical-mail",
    "ai-agent",
    "agent-skill",
    "claude",
    "claude-desktop",
    "cursor",
    "openclaw",
            "usps"
  ],
  "homepage": "https://postals.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coopergwrenn/postals-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/coopergwrenn/postals-mcp/issues"
  },
  "author": "Postals",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
